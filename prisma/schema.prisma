// MyFlip – schéma Prisma
// Docs : https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt      DateTime  @default(now())
}

model Commande {
  id          String    @id @default(cuid())
  date        DateTime  @default(now())
  fournisseur String
  nbArticles  Int
  coutTotal   Float
  marque      String?
  categorie   String?
  grade       String?
  coefObjectif Float?   @default(2.5)
  articles    Article[]
  createdAt   DateTime  @default(now())
}

model Article {
  id          String    @id @default(cuid())
  sku         String    @unique
  marque      String
  categorie   String
  grade       String?
  statut      String    @default("En stock")
  prixAchat   Float
  prixVente   Float?
  margeBrute  Float?
  margeNette  Float?
  coefficient Float?
  canal       String?   @default("Vinted")
  dateVente   DateTime?
  transporteur String?
  trelloCardId String?
  commandeId  String?
  commande    Commande? @relation(fields: [commandeId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  // Annonce générée (Mise en vente)
  titreAnnonce       String? @db.Text
  descriptionAnnonce String? @db.Text
  motsClesAnnonce    String? @db.Text

  @@index([statut])
  @@index([marque])
  @@index([trelloCardId])
  @@index([dateVente])
  @@index([commandeId])
}

// Prompt personnalisable pour la génération d'annonces via Gemini.
// Sélection par marque/catégorie (cf. lib/promptSelect), repli sur estDefaut.
model PromptTemplate {
  id        String   @id @default(cuid())
  nom       String
  marque    String? // critère de correspondance ; null = toutes les marques
  categorie String? // critère de correspondance ; null = toutes les catégories
  contenu   String   @db.Text // prompt avec placeholders {marque} {categorie} {taille} {etat} {matiere} {sku}
  estDefaut Boolean  @default(false) // prompt de repli si aucune correspondance
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marque])
  @@index([categorie])
  @@index([estDefaut])
}
