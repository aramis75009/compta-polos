# Base de données PostgreSQL (Neon, Supabase, etc.)
DATABASE_URL=

# Secret NextAuth — généré avec : npx auth secret
NEXTAUTH_SECRET=

# URL de l'application (http://localhost:3000 en dev)
NEXTAUTH_URL=http://localhost:3000

# Identifiants du compte unique (propriétaire)
AUTH_EMAIL=
# Hash bcrypt du mot de passe — voir README pour le générer
AUTH_PASSWORD=

# Secret NextAuth (v5) — généré avec : npx auth secret
AUTH_SECRET=
# Fait confiance au host (utile en dev / derrière proxy)
AUTH_TRUST_HOST=true

# Assistant IA (Anthropic)
ANTHROPIC_API_KEY=

# Intégration Trello
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LABEL_ID=
