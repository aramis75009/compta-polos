# Base de données PostgreSQL (Neon en production)
DATABASE_URL=

# ── Authentification (NextAuth v5) ──
# Les identifiants de connexion sont stockés EN BASE (table User, hash bcrypt).
# Créer le compte propriétaire avec : node scripts/init-user.mjs
AUTH_SECRET=              # généré avec : npx auth secret
AUTH_TRUST_HOST=true      # true en dev et derrière un proxy
NEXTAUTH_URL=http://localhost:3000

# ── IA ──
GEMINI_API_KEY=           # génération des annonces (page Mise en vente)
ANTHROPIC_API_KEY=        # chatbot

# ── Emails transactionnels (Resend) ──
RESEND_API_KEY=

# ── Intégration Trello ──
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LABEL_ID=              # étiquette « À comptabiliser » (violette) : déclenche l'entrée en compta
TRELLO_COMPTABILISE_LABEL_ID= # étiquette « Comptabilisé » (verte) : posée quand l'article est validé
# IDs des étiquettes du board :
#   GET https://api.trello.com/1/boards/{TRELLO_BOARD_ID}/labels?key={KEY}&token={TOKEN}

# ── Divers ──
NEXT_PUBLIC_USER_NAME=    # prénom affiché dans le dashboard
